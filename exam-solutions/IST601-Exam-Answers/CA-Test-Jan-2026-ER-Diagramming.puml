' IST601 CA Test on ER Diagramming - January 2026
' PlantUML code for all ER diagrams in CA-Test-Jan-2026-ER-Diagramming.md
' Use: export each @startuml...@enduml block to a separate file, or use PlantUML to render by diagram name.

' ==============================================================================
' Diagram 1: Question 1e - Department Has Employee (1:N) - Chen style
' ==============================================================================
@startuml(Q1e-Department-Employee-Chen)
!theme plain
skinparam linetype ortho
skinparam backgroundColor #FEFEFE

entity "Department" as dept {
  * DepartmentID --
  Name
}

entity "Employee" as emp {
  * EmployeeID --
  Name
}

entity "Has" as has <<relationship>> {
  --
}

dept -- has : "1"
has -- emp : "N"

@enduml

